---
import '../styles/global.css';
import AppHeader from '../components/shell/AppHeader.astro';
import ThemeManager from '../themes/ThemeManager';

interface Props {
	title: string;
	description?: string;
	mainClass?: string;
}

const { title, description = 'Bytekit 开发工具站', mainClass = '' } = Astro.props;
const mainClassName = ['site-main', mainClass].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
	<head>
		<script is:inline>
			(() => {
				try {
					const stored = window.localStorage.getItem('bytekit-theme');
					const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
					document.documentElement.dataset.theme = stored || (systemDark ? 'dark' : 'light');
					const themeId = window.localStorage.getItem('bytekit-theme-id');
					if (themeId) document.documentElement.dataset.themeId = themeId;
				} catch {
					document.documentElement.dataset.theme = 'light';
				}
			})();
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.ico`} />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<ThemeManager client:load>
			<AppHeader />
			<main class={mainClassName}>
				<slot />
			</main>
		</ThemeManager>
	</body>
</html>
