---
import {
	Braces,
	Code2,
	FileJson,
	FileText,
	LockKeyhole,
	Palette,
	Settings,
} from 'lucide-react';
import HomeToolCatalog from '../components/home/HomeToolCatalog';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getToolsByCategory, toolCategories } from '../lib/toolRegistry';

const iconByName = {
	braces: Braces,
	code: Code2,
	'file-json': FileJson,
	'file-text': FileText,
	lock: LockKeyhole,
	palette: Palette,
	settings: Settings,
};

export const prerender = true;
---

<BaseLayout title="Bytekit" description="Bytekit 在线工具箱，无需安装，高效便捷。">
	<div class="home-shell">
		<aside class="home-sidebar" aria-label="工具分类">
			<a class="home-brand" href={import.meta.env.BASE_URL} aria-label="Bytekit 首页">
				<span class="home-brand__mark">B</span>
				<span class="home-brand__text">Bytekit</span>
			</a>
			<nav class="home-category-nav">
				{toolCategories.map((category) => {
					const Icon = iconByName[category.icon];
					const count = getToolsByCategory(category.id).length;

					return (
						<a class="home-category-nav__item" href={`#${category.id}`}>
							<span class="home-category-nav__main">
								<Icon size={16} strokeWidth={2} aria-hidden="true" />
								{category.name}
							</span>
							<span class="home-category-nav__count">{count}</span>
						</a>
					);
				})}
			</nav>
		</aside>

		<section class="home-main">
			<HomeToolCatalog client:load />
		</section>
	</div>
</BaseLayout>

