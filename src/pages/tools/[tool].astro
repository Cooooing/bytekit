---
import ToolApp from '../../components/tools/ToolApp';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getToolById, tools } from '../../lib/toolRegistry';

export const prerender = true;

export function getStaticPaths() {
	return tools.map((tool) => ({ params: { tool: tool.id } }));
}

const { tool: toolId } = Astro.params;
const tool = getToolById(toolId ?? '');
---

<BaseLayout title={`${tool?.name ?? '工具'} - Bytekit`} description={tool?.description ?? ''}>
	<ToolApp client:load initialToolId={tool?.id ?? 'json'} />
</BaseLayout>
