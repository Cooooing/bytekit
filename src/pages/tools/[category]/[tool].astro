---
import AppShell from '../../../themes/default/components/AppShell';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getToolById, tools } from '../../../tools/registry';

export const prerender = true;

export function getStaticPaths() {
	return tools.map((tool) => {
		const [_, category, slug] = tool.href.split('/');
		return { params: { category, tool: slug } };
	});
}

const { tool: toolSlug, category } = Astro.params;
const tool = tools.find((t) => t.href === `tools/${category}/${toolSlug}`);
---

<BaseLayout title={`${tool?.name ?? '工具'} - Bytekit`} description={tool?.description ?? ''}>
	<AppShell client:load initialToolId={tool?.id ?? 'json'} />
</BaseLayout>
