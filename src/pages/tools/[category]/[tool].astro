---
import AppShell from '../../../features/tools/shell/AppShell';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { tools } from '@features/tools/core/registry';

export const prerender = true;

export function getStaticPaths() {
	return tools.map((tool) => {
		const [, category, slug] = tool.href.split('/');
		return { params: { category, tool: slug } };
	});
}

const { tool: toolSlug, category } = Astro.params;
const tool = tools.find((item) => item.href === `tools/${category}/${toolSlug}`);
---

<BaseLayout title={`${tool?.name ?? '工具'} - Bytekit`} description={tool?.description ?? ''} mainClass="site-main--tool">
	<AppShell client:load initialToolId={tool?.id ?? 'json'} />
</BaseLayout>
